CONTROL AUTOMATON ErrorPath3

INITIAL STATE ARG2;

STATE USEFIRST ARG2 :
    MATCH "" -> GOTO ARG8;
    TRUE -> STOP;

STATE USEFIRST ARG8 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG11_1_1;
STATE USEFIRST ARG11_0_1 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG11_1_1;
STATE USEFIRST ARG11_1_1 :
    MATCH "int main()" -> GOTO ARG11_2_1;
STATE USEFIRST ARG11_2_1 :
    MATCH "" -> GOTO ARG11_3_1;
STATE USEFIRST ARG11_3_1 :
    MATCH "int val = __VERIFIER_nondet_int();" -> GOTO ARG11_4_1;
STATE USEFIRST ARG11_4_1 :
    MATCH "int val = __VERIFIER_nondet_int();" -> GOTO ARG11;
    TRUE -> STOP;

STATE USEFIRST ARG11 :
    MATCH "[[!(!val)]]" -> GOTO ARG15;
    TRUE -> STOP;

STATE USEFIRST ARG15 :
    MATCH "int bits;" -> GOTO ARG18_1_2;
STATE USEFIRST ARG18_0_2 :
    MATCH "int bits;" -> GOTO ARG18_1_2;
STATE USEFIRST ARG18_1_2 :
    MATCH "" -> GOTO ARG18;
    TRUE -> STOP;

STATE USEFIRST ARG18 :
    MATCH "bits = 0" -> GOTO ARG23;
    TRUE -> STOP;

STATE USEFIRST ARG23 :
    MATCH "[[val != 0]]" -> GOTO ARG40;
    TRUE -> STOP;

STATE USEFIRST ARG40 :
    MATCH "val >>= 1;" -> GOTO ARG50_1_3;
STATE USEFIRST ARG50_0_3 :
    MATCH "val >>= 1;" -> GOTO ARG50_1_3;
STATE USEFIRST ARG50_1_3 :
    MATCH "" -> GOTO ARG50;
    TRUE -> STOP;

STATE USEFIRST ARG50 :
    MATCH "bits++" -> ERROR;
    TRUE -> STOP;

STATE USEFIRST ARG246 :
    TRUE -> STOP;

END AUTOMATON
