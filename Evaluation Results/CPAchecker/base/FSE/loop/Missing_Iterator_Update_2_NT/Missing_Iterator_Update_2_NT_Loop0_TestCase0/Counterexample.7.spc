CONTROL AUTOMATON ErrorPath7

INITIAL STATE ARG2;

STATE USEFIRST ARG2 :
    MATCH "" -> GOTO ARG1670;
    TRUE -> STOP;

STATE USEFIRST ARG1670 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG1672_1_1;
STATE USEFIRST ARG1672_0_1 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG1672_1_1;
STATE USEFIRST ARG1672_1_1 :
    MATCH "int flag = 0;" -> GOTO ARG1672_2_1;
STATE USEFIRST ARG1672_2_1 :
    MATCH "int mdb_cursor_get()" -> GOTO ARG1672_3_1;
STATE USEFIRST ARG1672_3_1 :
    MATCH "int main()" -> GOTO ARG1672_4_1;
STATE USEFIRST ARG1672_4_1 :
    MATCH "" -> GOTO ARG1672_5_1;
STATE USEFIRST ARG1672_5_1 :
    MATCH "int rc;" -> GOTO ARG1672;
    TRUE -> STOP;

STATE USEFIRST ARG1672 :
    MATCH "rc = mdb_cursor_get();" -> GOTO ARG1674;
    TRUE -> STOP;

STATE USEFIRST ARG1674 :
    MATCH "" -> GOTO ARG1676_1_2;
STATE USEFIRST ARG1676_0_2 :
    MATCH "" -> GOTO ARG1676_1_2;
STATE USEFIRST ARG1676_1_2 :
    MATCH "int i = __VERIFIER_nondet_int();" -> GOTO ARG1676_2_2;
STATE USEFIRST ARG1676_2_2 :
    MATCH "int i = __VERIFIER_nondet_int();" -> GOTO ARG1676_3_2;
STATE USEFIRST ARG1676_3_2 :
    MATCH "flag++;" -> GOTO ARG1676_4_2;
STATE USEFIRST ARG1676_4_2 :
    MATCH "flag++;" -> GOTO ARG1676_5_2;
STATE USEFIRST ARG1676_5_2 :
    MATCH "flag++;" -> GOTO ARG1676;
    TRUE -> STOP;

STATE USEFIRST ARG1676 :
    MATCH "[[flag > 1000]]" -> GOTO ARG1679;
    MATCH "[[!(flag > 1000)]]" -> GOTO ARG1680;
    TRUE -> STOP;

STATE USEFIRST ARG1679 :
    MATCH "return 1;" -> GOTO ARG1695;
    TRUE -> STOP;

STATE USEFIRST ARG1680 :
    MATCH "[[i >= 0]]" -> GOTO ARG1683;
    MATCH "[[!(i >= 0)]]" -> GOTO ARG1685;
    TRUE -> STOP;

STATE USEFIRST ARG1683 :
    MATCH "return 0;" -> GOTO ARG1695;
    TRUE -> STOP;

STATE USEFIRST ARG1685 :
    MATCH "return 1;" -> GOTO ARG1695;
    TRUE -> STOP;

STATE USEFIRST ARG1695 :
    MATCH "" -> GOTO ARG1700;
    TRUE -> STOP;

STATE USEFIRST ARG1700 :
    MATCH "int dval_mv_size = __VERIFIER_nondet_int();" -> GOTO ARG1702_1_3;
STATE USEFIRST ARG1702_0_3 :
    MATCH "int dval_mv_size = __VERIFIER_nondet_int();" -> GOTO ARG1702_1_3;
STATE USEFIRST ARG1702_1_3 :
    MATCH "int dval_mv_size = __VERIFIER_nondet_int();" -> GOTO ARG1702;
    TRUE -> STOP;

STATE USEFIRST ARG1702 :
    MATCH "" -> GOTO ARG1937;
    TRUE -> STOP;

STATE USEFIRST ARG1937 :
    MATCH "[[rc == 0]]" -> GOTO ARG1948;
    TRUE -> STOP;

STATE USEFIRST ARG1948 :
    MATCH "[[dval_mv_size <= 0]]" -> GOTO ARG1959;
    TRUE -> STOP;

STATE USEFIRST ARG1959 :
    MATCH "continue;" -> ERROR;
    TRUE -> STOP;

STATE USEFIRST ARG2447 :
    TRUE -> STOP;

END AUTOMATON
