CONTROL AUTOMATON ErrorPath5

INITIAL STATE ARG2;

STATE USEFIRST ARG2 :
    MATCH "" -> GOTO ARG743;
    TRUE -> STOP;

STATE USEFIRST ARG743 :
    MATCH "extern unsigned char __VERIFIER_nondet_uchar(void);" -> GOTO ARG745_1_1;
STATE USEFIRST ARG745_0_1 :
    MATCH "extern unsigned char __VERIFIER_nondet_uchar(void);" -> GOTO ARG745_1_1;
STATE USEFIRST ARG745_1_1 :
    MATCH "int main()" -> GOTO ARG745_2_1;
STATE USEFIRST ARG745_2_1 :
    MATCH "" -> GOTO ARG745_3_1;
STATE USEFIRST ARG745_3_1 :
    MATCH "unsigned char l = 1;" -> GOTO ARG745;
    TRUE -> STOP;

STATE USEFIRST ARG745 :
    MATCH "" -> GOTO ARG909;
    TRUE -> STOP;

STATE USEFIRST ARG909 :
    MATCH "l--" -> GOTO ARG923_1_2;
STATE USEFIRST ARG923_0_2 :
    MATCH "l--" -> GOTO ARG923_1_2;
STATE USEFIRST ARG923_1_2 :
    MATCH "l--" -> GOTO ARG923;
    TRUE -> STOP;

STATE USEFIRST ARG923 :
    MATCH "[[l--]]" -> GOTO ARG929;
    TRUE -> STOP;

STATE USEFIRST ARG929 :
    MATCH "l--" -> GOTO ARG933_1_3;
STATE USEFIRST ARG933_0_3 :
    MATCH "l--" -> GOTO ARG933_1_3;
STATE USEFIRST ARG933_1_3 :
    MATCH "l--" -> GOTO ARG933;
    TRUE -> STOP;

STATE USEFIRST ARG933 :
    MATCH "[[l--]]" -> GOTO ARG942;
    MATCH "[[!(l--)]]" -> GOTO ARG948;
    TRUE -> STOP;

STATE USEFIRST ARG942 :
    MATCH "" -> GOTO ARG948;
    TRUE -> STOP;

STATE USEFIRST ARG948 :
    MATCH "" -> GOTO ARG988;
    TRUE -> STOP;

STATE USEFIRST ARG988 :
    MATCH "l--" -> GOTO ARG1000_1_4;
STATE USEFIRST ARG1000_0_4 :
    MATCH "l--" -> GOTO ARG1000_1_4;
STATE USEFIRST ARG1000_1_4 :
    MATCH "l--" -> GOTO ARG1000;
    TRUE -> STOP;

STATE USEFIRST ARG1000 :
    MATCH "[[l--]]" -> GOTO ARG1006;
    TRUE -> STOP;

STATE USEFIRST ARG1006 :
    MATCH "l--" -> GOTO ARG1014_1_5;
STATE USEFIRST ARG1014_0_5 :
    MATCH "l--" -> GOTO ARG1014_1_5;
STATE USEFIRST ARG1014_1_5 :
    MATCH "l--" -> GOTO ARG1014;
    TRUE -> STOP;

STATE USEFIRST ARG1014 :
    MATCH "[[l--]]" -> GOTO ARG1020;
    MATCH "[[!(l--)]]" -> GOTO ARG1027;
    TRUE -> STOP;

STATE USEFIRST ARG1020 :
    MATCH "" -> GOTO ARG1027;
    TRUE -> STOP;

STATE USEFIRST ARG1027 :
    MATCH "" -> ERROR;
    TRUE -> STOP;

STATE USEFIRST ARG1288 :
    TRUE -> STOP;

END AUTOMATON
