CONTROL AUTOMATON ErrorPath3

INITIAL STATE ARG2;

STATE USEFIRST ARG2 :
    MATCH "" -> GOTO ARG6;
    TRUE -> STOP;

STATE USEFIRST ARG6 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG10_1_1;
STATE USEFIRST ARG10_0_1 :
    MATCH "extern int __VERIFIER_nondet_int(void);" -> GOTO ARG10_1_1;
STATE USEFIRST ARG10_1_1 :
    MATCH "int main()" -> GOTO ARG10_2_1;
STATE USEFIRST ARG10_2_1 :
    MATCH "" -> GOTO ARG10_3_1;
STATE USEFIRST ARG10_3_1 :
    MATCH "int val = -1000;" -> GOTO ARG10;
    TRUE -> STOP;

STATE USEFIRST ARG10 :
    MATCH "[[!(!val)]]" -> GOTO ARG15;
    TRUE -> STOP;

STATE USEFIRST ARG15 :
    MATCH "int bits;" -> GOTO ARG17_1_2;
STATE USEFIRST ARG17_0_2 :
    MATCH "int bits;" -> GOTO ARG17_1_2;
STATE USEFIRST ARG17_1_2 :
    MATCH "" -> GOTO ARG17;
    TRUE -> STOP;

STATE USEFIRST ARG17 :
    MATCH "bits = 0" -> GOTO ARG22;
    TRUE -> STOP;

STATE USEFIRST ARG22 :
    MATCH "[[val != 0]]" -> GOTO ARG36;
    TRUE -> STOP;

STATE USEFIRST ARG36 :
    MATCH "val >>= 1;" -> GOTO ARG48_1_3;
STATE USEFIRST ARG48_0_3 :
    MATCH "val >>= 1;" -> GOTO ARG48_1_3;
STATE USEFIRST ARG48_1_3 :
    MATCH "" -> GOTO ARG48;
    TRUE -> STOP;

STATE USEFIRST ARG48 :
    MATCH "bits++" -> ERROR;
    TRUE -> STOP;

STATE USEFIRST ARG211 :
    TRUE -> STOP;

END AUTOMATON
