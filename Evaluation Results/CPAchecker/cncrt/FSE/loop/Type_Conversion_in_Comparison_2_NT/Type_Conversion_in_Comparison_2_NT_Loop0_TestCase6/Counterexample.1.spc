    MATCH "[ac != c2]" -> ASSUME {ac == (249U);c2 == (-6);} GOTO ARG875;
    TRUE -> STOP;

STATE USEFIRST ARG875 :
    MATCH "" -> GOTO ARG876;
    TRUE -> STOP;

STATE USEFIRST ARG876 :
    MATCH "ac++" -> ERROR;
    TRUE -> STOP;

STATE USEFIRST ARG877 :
    TRUE -> STOP;

END AUTOMATON
