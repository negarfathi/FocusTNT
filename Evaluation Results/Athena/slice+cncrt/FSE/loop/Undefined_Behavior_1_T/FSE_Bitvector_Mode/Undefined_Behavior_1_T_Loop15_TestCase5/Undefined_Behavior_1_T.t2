///*** 1_main ***///
START: main_bb0;

TYPE vnum.0: bv(32);

FROM: main_bb0;
v0 := 1048575 + 1;
var__temp_vnum.0 := v0;
TO: main_bb1;

FROM: main_bb1;
vnum.0 := var__temp_vnum.0;
v1 := lshr(vnum.0, 7);
var__temp_vnum.0 := v1;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v1 != 0);
TO: main_bb1;

FROM: main_bb1_end;
assume(v1 == 0);
TO: main_bb2;

FROM: main_bb2;
TO: main_bb2_ret;

