///*** 1_main ***///
START: main_bb0;

TYPE vsmallest.0: bv(32);

FROM: main_bb0;
var__temp_vsmallest.0 := 1;
TO: main_bb1;

FROM: main_bb1;
vsmallest.0 := var__temp_vsmallest.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume((vsmallest.0 sgt -5) || (vsmallest.0 == 0));
TO: main_bb2;

FROM: main_bb1_end;
assume((vsmallest.0 sle -5) && (vsmallest.0 != 0));
TO: main_bb3;

FROM: main_bb2;
TO: main_bb2_ret;

FROM: main_bb3;
v2 := shl(vsmallest.0, 1);
var__temp_vsmallest.0 := v2;
TO: main_bb1;

