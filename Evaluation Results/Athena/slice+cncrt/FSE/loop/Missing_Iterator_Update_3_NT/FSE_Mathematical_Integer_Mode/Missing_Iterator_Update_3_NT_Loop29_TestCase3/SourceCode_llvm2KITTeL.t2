///*** 1_main ***///
START: main_bb1;

FROM: main_bb1;
memory0_freeIndex := 1;
vmemory0 := nondet();
TO: main_bb1_end;

FROM: main_bb1_end;
assume(1 <= 0);
TO: main_bb6;

FROM: main_bb1_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb2;
v4 := sign_extend(32, 64, 3);
v5 := 4 * v4;
var__temp_vi.0 := 0;
TO: main_bb3;

FROM: main_bb3;
vi.0 := var__temp_vi.0;
v8 := 3 - 1;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(vi.0 slt v8);
TO: main_bb4;

FROM: main_bb3_end;
assume(vi.0 sge v8);
TO: main_bb5;

FROM: main_bb4;
v10 := nondet();
v11 := v7 + vi.0;
v12 := sign_extend(32, 64, v11);
v13 := v12;
vmemory0 := store_array(vmemory0, v13, v10);
v14 := vi.0 + 1;
var__temp_vi.0 := v14;
TO: main_bb3;

FROM: main_bb5;
v15 := 3 - 1;
v16 := v7 + v15;
v17 := sign_extend(32, 64, v16);
v18 := v17;
vmemory0 := store_array(vmemory0, v18, 0);
TO: main_bb6;

FROM: main_bb6;
TO: main_bb6_ret;

