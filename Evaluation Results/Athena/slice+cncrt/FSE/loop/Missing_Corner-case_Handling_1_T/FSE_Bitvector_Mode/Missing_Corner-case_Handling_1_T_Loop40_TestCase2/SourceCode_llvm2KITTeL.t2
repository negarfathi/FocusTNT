///*** 1_main ***///
START: main_bb6;

FROM: main_bb6;
flag := 0;
count := 0;
v9 := flag;
v10 := count;
TO: main_read_slice_1.exit;

FROM: main_read_slice_1.exit;
TO: main_read_slice_1.exit_v.;
FROM: main_read_slice_1.exit_v.;
assume((v9 == 1) || (v10 sgt 100));
v. := 0;
TO: main_read_slice_1.exit_sv.;

FROM: main_read_slice_1.exit_v.;
assume((v9 != 1) && (v10 sle 100));
v. := -1;
TO: main_read_slice_1.exit_sv.;

FROM: main_read_slice_1.exit_sv.;
TO: main_read_slice_1.exit_end;

FROM: main_read_slice_1.exit_end;
assume(v. sle 0);
TO: main_bb7;

FROM: main_read_slice_1.exit_end;
assume(v. sgt 0);
TO: main_read_slice_1.exit;

FROM: main_bb7;
TO: main_bb7_ret;

