///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
gtv_0 := 0;
var__temp_vbytes.0 := 1;
TO: main_bb1;

FROM: main_bb1;
vbytes.0 := var__temp_vbytes.0;
v0 := vbytes.0 * 8;
gtv_0 := v0;
v1 := lshr(256, v0);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v1 != 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(v1 == 0);
TO: main_bb3;

FROM: main_bb2;
v3 := vbytes.0 + 1;
var__temp_vbytes.0 := v3;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

