///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vi.0 := 0;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb5;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
var__temp_vj.0 := 0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 slt 10);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sge 10);
TO: main_bb5;

FROM: main_bb2;
vj.0 := var__temp_vj.0;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(vj.0 slt 20);
TO: main_bb3;

FROM: main_bb2_end;
assume(vj.0 sge 20);
TO: main_bb4;

FROM: main_bb3;
v4 := vj.0 + 1;
var__temp_vj.0 := v4;
TO: main_bb2;

FROM: main_bb4;
v5 := vi.0 + 1;
var__temp_vi.0 := v5;
TO: main_bb1;

FROM: main_bb5;
TO: main_bb5_ret;

