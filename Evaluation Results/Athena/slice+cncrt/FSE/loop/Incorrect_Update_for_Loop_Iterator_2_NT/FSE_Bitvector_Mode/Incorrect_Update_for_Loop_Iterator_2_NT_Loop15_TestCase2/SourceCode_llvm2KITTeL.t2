///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vl.0 := 2;
TO: main_bb1;

FROM: main_bb1;
vl.0 := var__temp_vl.0;
v0 := zero_extend(8, 32, vl.0);
v1 := v0 - 1;
v2 := extract(7, 0, v1);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vl.0 != 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vl.0 == 0);
TO: main_bb3;

FROM: main_bb2;
v4 := zero_extend(8, 32, v2);
v5 := v4 - 1;
v6 := extract(7, 0, v5);
var__temp_vl.0 := v6;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

