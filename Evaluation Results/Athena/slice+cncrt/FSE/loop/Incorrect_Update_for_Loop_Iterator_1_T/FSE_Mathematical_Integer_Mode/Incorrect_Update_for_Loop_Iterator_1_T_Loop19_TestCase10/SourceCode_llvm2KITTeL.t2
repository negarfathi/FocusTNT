TO: main_bb1;

FROM: main_bb1;
vsize.0 := var__temp_vsize.0;
vbuffer_bytes_left.0 := var__temp_vbuffer_bytes_left.0;
v3 := vsize.0 sdiv 2;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vbuffer_bytes_left.0 slt v3);
TO: main_bb2;

FROM: main_bb1_end;
assume(vbuffer_bytes_left.0 sge v3);
