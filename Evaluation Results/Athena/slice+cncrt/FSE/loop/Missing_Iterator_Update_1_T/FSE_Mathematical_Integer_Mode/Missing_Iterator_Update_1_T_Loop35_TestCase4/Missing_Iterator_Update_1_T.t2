///*** 1_main ***///
START: main_bb3;
TYPE dummy: bv(32);


FROM: main_bb3;
errno := 0;
errno := 2;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(1 <= 0);
TO: main_bb4;

FROM: main_bb3_end;
assume(0 <= 0);
TO: main_.critedge;

FROM: main_bb4;
errno := 2;
v3 := errno;
TO: main_bb4_end;

FROM: main_bb4_end;
assume(v3 == 1);
TO: main_bb4;

FROM: main_bb4_end;
assume(v3 != 1);
TO: main_.critedge;

FROM: main_.critedge;
TO: main_.critedge_ret;

