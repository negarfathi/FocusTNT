TO: main_bb6_end;

FROM: main_bb6_end;
assume(0 <= 0);
TO: main_bb6;

FROM: main_bb6_end;
assume(1 <= 0);
TO: main_bb7;

FROM: main_bb7;
TO: main_bb7_ret;

