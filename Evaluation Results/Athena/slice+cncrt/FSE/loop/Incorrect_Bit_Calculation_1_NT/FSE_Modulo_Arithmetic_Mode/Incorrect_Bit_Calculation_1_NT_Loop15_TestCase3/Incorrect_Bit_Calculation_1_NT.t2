///*** 1_main ***///
START: main_bb0;

TYPE vmask.0: bv(32);

FROM: main_bb0;
var__temp_vmask.0 := 5;
TO: main_bb1;

FROM: main_bb1;
vmask.0 := var__temp_vmask.0;
v0 := and(vmask.0, 1);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v0 == 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(v0 != 0);
TO: main_bb3;

FROM: main_bb2;
v2 := ashr(vmask.0, 1);
var__temp_vmask.0 := v2;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

