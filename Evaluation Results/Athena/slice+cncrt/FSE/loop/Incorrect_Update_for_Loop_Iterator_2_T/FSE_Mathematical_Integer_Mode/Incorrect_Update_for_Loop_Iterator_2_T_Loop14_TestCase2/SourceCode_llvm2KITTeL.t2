TO: main_bb2_end;

FROM: main_bb2_end;
assume(v2 != 0);
TO: main_bb3;

FROM: main_bb2_end;
assume(v2 == 0);
TO: main_bb1;

FROM: main_bb3;
v5 := zero_extend(8, 32, v2);
v6 := v5 - 1;
v7 := extract(7, 0, v6);
var__temp_vl.0 := v7;
TO: main_bb1;

FROM: main_bb4;
TO: main_bb4_ret;

