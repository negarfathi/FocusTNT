///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vcur.0 := 5;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1;
vcur.0 := var__temp_vcur.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(10 ult vcur.0);
TO: main_bb2;

FROM: main_bb1_end;
assume(10 uge vcur.0);
TO: main_bb3;

FROM: main_bb2;
TO: main_bb2_ret;

FROM: main_bb3;
v3 := vcur.0 + 5;
var__temp_vcur.0 := v3;
TO: main_bb1;

