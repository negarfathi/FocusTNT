///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb2;
TO: main_bb2_ret;

