///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vi.0 := 0;
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 slt 5);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sge 5);
TO: main_bb3;

FROM: main_bb2;
v1 := vi.0 + 1;
var__temp_vi.0 := v1;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

