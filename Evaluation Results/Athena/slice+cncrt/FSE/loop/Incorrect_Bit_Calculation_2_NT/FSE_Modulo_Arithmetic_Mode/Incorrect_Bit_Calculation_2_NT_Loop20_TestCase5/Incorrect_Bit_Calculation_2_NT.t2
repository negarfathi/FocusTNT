///*** 1_main ***///
START: main_bb0;

TYPE va0.0: bv(32);
TYPE v2: bv(32);
TYPE v3: bv(32);
TYPE va1.0: bv(32);

FROM: main_bb0;
gtv_0 := 0;
gtv_1 := 0;
var__temp_va1.0 := 7;
var__temp_va0.0 := 6;
TO: main_bb1;

FROM: main_bb1;
va1.0 := var__temp_va1.0;
va0.0 := var__temp_va0.0;
v0 := and(va0.0, 1);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v0 == 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(v0 != 0);
TO: main_bb3;

FROM: main_bb2;
v2 := shl(va1.0, 31);
gtv_0 := v2;
v3 := ashr(va0.0, 1);
gtv_1 := v3;
v4 := or(v2, v3);
v5 := ashr(va1.0, 1);
var__temp_va1.0 := v5;
var__temp_va0.0 := v4;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

