///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
vmain.slots_used := nondet();
vslots_used := nondet();
vereg := nondet();
v0 := v1;
v4 := 3;
v3 := store_array(v3, v4, 5);
var__temp_vi.0 := 0;
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 slt 10);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sge 10);
TO: main_bb3;

FROM: main_bb2;
v6 := vi.0 + 1;
var__temp_vi.0 := v6;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

