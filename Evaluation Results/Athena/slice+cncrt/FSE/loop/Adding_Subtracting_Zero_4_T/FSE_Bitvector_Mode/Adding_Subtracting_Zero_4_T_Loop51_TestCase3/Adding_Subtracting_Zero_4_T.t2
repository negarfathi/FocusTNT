vtries.0 := var__temp_vtries.0;
vbuf.0 := var__temp_vbuf.0;
vcount.0 := var__temp_vcount.0;
TO: main_bb9_end;

FROM: main_bb9_end;
assume(vcount.0 sgt 0);
TO: main_bb10;

FROM: main_bb9_end;
assume(vcount.0 sle 0);
TO: main_bb16;

FROM: main_bb10;
var__temp_vcount.0.i := 0;
var__temp_v.0.i := vbuf.0;
var__temp_v__retres.0.i := 0;
TO: main_bb10_end;

FROM: main_bb10_end;
assume(v11 == 1);
TO: main_read_slice_1.exit;

FROM: main_bb10_end;
assume(v11 != 1);
TO: main_bb11;

FROM: main_bb11;
vcount.0.i := var__temp_vcount.0.i;
v.0.i := var__temp_v.0.i;
var__temp_v__retres.0.i := vcount.0.i;
TO: main_bb11_end;

FROM: main_bb11_end;
assume(v.0.i slt vcount.0);
TO: main_bb12;

FROM: main_bb11_end;
assume(v.0.i sge vcount.0);
TO: main_read_slice_1.exit;

FROM: main_bb12;
v15 := vcount.0.i + 1;
v16 := v.0.i + 1;
var__temp_vcount.0.i := v15;
var__temp_v.0.i := v16;
TO: main_bb11;

FROM: main_read_slice_1.exit;
v__retres.0.i := var__temp_v__retres.0.i;
TO: main_read_slice_1.exit_end;

FROM: main_read_slice_1.exit_end;
assume(v__retres.0.i sle 0);
TO: main_bb13;

FROM: main_read_slice_1.exit_end;
assume(v__retres.0.i sgt 0);
TO: main_bb15;

FROM: main_bb13;
TO: main_bb13_end;

FROM: main_bb13_end;
assume(v__retres.0.i == 0);
TO: main_bb14;

FROM: main_bb13_end;
assume(v__retres.0.i != 0);
TO: main_bb16;

FROM: main_bb14;
v19 := vtries.0 + 1;
var__temp_vtries.0 := v19;
var__temp_vbuf.0 := vbuf.0;
var__temp_vcount.0 := vcount.0;
