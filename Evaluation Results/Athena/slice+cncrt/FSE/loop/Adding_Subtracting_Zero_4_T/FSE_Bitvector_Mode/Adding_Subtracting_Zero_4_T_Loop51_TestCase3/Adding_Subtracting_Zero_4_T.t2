FROM: main_bb14_end;
assume(vtries.0 slt 5);
TO: main_bb9;

FROM: main_bb14_end;
assume(vtries.0 sge 5);
TO: main_bb16;

FROM: main_bb15;
v21 := vcount.0 - v__retres.0.i;
v22 := vbuf.0 + v__retres.0.i;
var__temp_vtries.0 := vtries.0;
var__temp_vbuf.0 := v22;
var__temp_vcount.0 := v21;
