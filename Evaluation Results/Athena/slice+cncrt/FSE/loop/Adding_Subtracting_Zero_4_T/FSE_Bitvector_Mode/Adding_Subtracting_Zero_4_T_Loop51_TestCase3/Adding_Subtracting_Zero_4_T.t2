assume(1 <= 0);
TO: main_bb16;

FROM: main_bb7_end;
assume(0 <= 0);
TO: main_bb8;

FROM: main_bb8;
v11 := flag;
var__temp_vtries.0 := 0;
var__temp_vbuf.0 := 0;
var__temp_vcount.0 := 3;
TO: main_bb9;

