///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
v0 := zero_extend(8, 32, 10);
var__temp_vac.0 := 5;
TO: main_bb1;

FROM: main_bb1;
vac.0 := var__temp_vac.0;
v1 := zero_extend(8, 32, vac.0);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v1 != v0);
TO: main_bb2;

FROM: main_bb1_end;
assume(v1 == v0);
TO: main_bb3;

FROM: main_bb2;
v3 := vac.0 + 1;
var__temp_vac.0 := v3;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

