///*** 1_main ***///
START: main_mdb_cursor_get.exit;
TYPE dummy: bv(32);


FROM: main_mdb_cursor_get.exit;
flag := 0;
v5 := flag;
v6 := v5 + 1;
flag := v6;
TO: main_bb3;

FROM: main_bb3;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(1 <= 0);
TO: main_bb4;

FROM: main_bb3_end;
assume(0 <= 0);
TO: main_bb5;

FROM: main_bb4;
v8 := flag;
v9 := v8 + 1;
flag := v9;
TO: main_bb3;

FROM: main_bb5;
TO: main_bb5_ret;

