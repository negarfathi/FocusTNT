///*** 1_main ***///
START: main_bb2;

FROM: main_bb2;
flag := 0;
var__temp_vmatroska.0 := 6;
TO: main_bb3;

FROM: main_bb3;
vmatroska.0 := var__temp_vmatroska.0;
TO: main_bb3_v..i;
FROM: main_bb3_v..i;
assume(vmatroska.0 == 1);
v..i := 0;
TO: main_bb3_sv..i;

FROM: main_bb3_v..i;
assume(vmatroska.0 != 1);
v..i := 1;
TO: main_bb3_sv..i;

FROM: main_bb3_sv..i;
var__temp_vres.0 := 0;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(v..i != 0);
TO: main_bb4;

FROM: main_bb3_end;
assume(v..i == 0);
TO: main_bb7;

FROM: main_bb4;
vres.0 := var__temp_vres.0;
TO: main_NodeBlock;

FROM: main_NodeBlock;
TO: main_NodeBlock_end;

FROM: main_NodeBlock_end;
assume(vres.0 slt 0);
TO: main_LeafBlock;

FROM: main_NodeBlock_end;
assume(vres.0 sge 0);
TO: main_LeafBlock4;

FROM: main_LeafBlock;
TO: main_LeafBlock_end;

FROM: main_LeafBlock_end;
assume(vres.0 == -1);
TO: main_bb5;

FROM: main_LeafBlock_end;
assume(vres.0 != -1);
TO: main_NewDefault;

FROM: main_bb5;
var__temp_vmatroska.0 := 1;
TO: main_bb3;

FROM: main_LeafBlock4;
TO: main_LeafBlock4_end;

FROM: main_LeafBlock4_end;
assume(vres.0 == 0);
TO: main_bb6;

FROM: main_LeafBlock4_end;
assume(vres.0 != 0);
TO: main_NewDefault;

FROM: main_bb6;
v6 := flag;
v7 := v6 + 1;
flag := v7;
TO: main_bb6_v..i1;
FROM: main_bb6_v..i1;
assume(v6 slt 100);
v..i1 := 2;
TO: main_bb6_sv..i1;

FROM: main_bb6_v..i1;
assume(v6 sge 100);
v..i1 := -1;
TO: main_bb6_sv..i1;

FROM: main_bb6_sv..i1;
var__temp_vres.0 := v..i1;
TO: main_bb4;

FROM: main_NewDefault;
var__temp_vmatroska.0 := vmatroska.0;
TO: main_bb3;

FROM: main_bb7;
TO: main_bb7_ret;

