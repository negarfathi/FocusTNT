///*** 1_main ***///
START: main_bb1;

FROM: main_bb1;
v3 := sign_extend(32, 64, 80000);
var__temp_vi.0 := 0;
TO: main_bb2;

FROM: main_bb2;
vi.0 := var__temp_vi.0;
v4 := zero_extend(16, 64, vi.0);
TO: main_bb2_end;

FROM: main_bb2_end;
assume(v4 ult v3);
TO: main_bb3;

FROM: main_bb2_end;
assume(v4 uge v3);
TO: main_bb4;

FROM: main_bb3;
v6 := vi.0 + 1;
var__temp_vi.0 := v6;
TO: main_bb2;

FROM: main_bb4;
TO: main_bb4_ret;

