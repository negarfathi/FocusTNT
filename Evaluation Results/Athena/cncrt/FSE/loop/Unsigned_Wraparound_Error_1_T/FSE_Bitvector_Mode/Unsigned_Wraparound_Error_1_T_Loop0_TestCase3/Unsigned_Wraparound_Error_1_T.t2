///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vcur.0 := 1;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb3;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb1;

FROM: main_bb1;
vcur.0 := var__temp_vcur.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(100 ult vcur.0);
TO: main_bb3;

FROM: main_bb1_end;
assume(100 uge vcur.0);
TO: main_bb2;

FROM: main_bb2;
v3 := vcur.0 + 1;
var__temp_vcur.0 := v3;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(v3 ule vcur.0);
TO: main_bb3;

FROM: main_bb2_end;
assume(v3 ugt vcur.0);
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

