v9 := flag;
v10 := v9 + 1;
flag := v10;
var__temp_v.0.i := 255;
TO: main_fgetc.exit;

FROM: main_fgetc.exit;
v.0.i := var__temp_v.0.i;
v11 := extract(7, 0, v.0.i);
v12 := zero_extend(8, 32, v11);
v14 := zero_extend(8, 32, v11);
