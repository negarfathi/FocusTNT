///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vnfds.0 := 2;
TO: main_bb1;

FROM: main_bb1;
vnfds.0 := var__temp_vnfds.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vnfds.0 sle 200);
TO: main_bb2;

FROM: main_bb1_end;
assume(vnfds.0 sgt 200);
TO: main_bb3;

FROM: main_bb2;
v1 := vnfds.0 * 2;
TO: main_bb2_v.;
FROM: main_bb2_v.;
assume(v1 sgt 100);
v. := 100;
TO: main_bb2_sv.;

FROM: main_bb2_v.;
assume(v1 sle 100);
v. := v1;
TO: main_bb2_sv.;

FROM: main_bb2_sv.;
var__temp_vnfds.0 := v.;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

