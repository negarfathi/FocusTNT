var__temp_vret.1 := vret.0;
TO: main_waitpid.exit_end;

FROM: main_waitpid.exit_end;
assume(vret.0 == 0);
TO: main_bb13;

FROM: main_waitpid.exit_end;
assume(vret.0 != 0);
TO: main_waitpid.exit1;

FROM: main_bb13;
v18 := errno;
