///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vbits.0 := 0;
var__temp_vval.0 := -2;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb3;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1;
vbits.0 := var__temp_vbits.0;
vval.0 := var__temp_vval.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vval.0 != 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vval.0 == 0);
TO: main_bb3;

FROM: main_bb2;
v2 := ashr(vval.0, 1);
v3 := vbits.0 + 1;
var__temp_vbits.0 := v3;
var__temp_vval.0 := v2;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

