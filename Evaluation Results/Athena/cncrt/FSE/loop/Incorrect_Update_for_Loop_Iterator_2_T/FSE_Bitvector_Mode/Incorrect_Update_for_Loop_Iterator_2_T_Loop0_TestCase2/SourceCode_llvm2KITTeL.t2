///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vl.0 := 2;
TO: main_bb1;

FROM: main_bb1;
vl.0 := var__temp_vl.0;
v0 := vl.0 + -1;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vl.0 != 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vl.0 == 0);
TO: main_bb3;

FROM: main_bb2;
v2 := zero_extend(8, 32, v0);
v4 := v0 + -1;
TO: main_bb2_v.;
FROM: main_bb2_v.;
assume(v2 != 0);
v. := v4;
TO: main_bb2_sv.;

FROM: main_bb2_v.;
assume(v2 == 0);
v. := v0;
TO: main_bb2_sv.;

FROM: main_bb2_sv.;
var__temp_vl.0 := v.;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

