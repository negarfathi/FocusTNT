///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vpkt.0 := 12;
TO: main_bb1;

FROM: main_bb1;
vpkt.0 := var__temp_vpkt.0;
var__temp_vres.0 := 0;
var__temp_vpkt.1 := vpkt.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vpkt.0 slt 10);
TO: main_bb2;

FROM: main_bb1_end;
assume(vpkt.0 sge 10);
TO: main_bb4;

FROM: main_bb2;
vres.0 := var__temp_vres.0;
vpkt.1 := var__temp_vpkt.1;
var__temp_vpkt.0 := vpkt.1;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(vres.0 == 0);
TO: main_bb3;

FROM: main_bb2_end;
assume(vres.0 != 0);
TO: main_bb1;

FROM: main_bb3;
v2 := vpkt.1 + 1;
var__temp_vpkt.0 := v2;
var__temp_vres.0 := 3;
var__temp_vpkt.1 := v2;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb3_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb4;
TO: main_bb4_ret;

