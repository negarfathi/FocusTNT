///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vi.0 := 0;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb3;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
var__temp_vi.1 := 0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 slt 20);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sge 20);
TO: main_bb3;

FROM: main_bb2;
vi.1 := var__temp_vi.1;
v4 := vi.1 + 1;
var__temp_vi.0 := v4;
var__temp_vi.1 := v4;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(vi.1 slt 10);
TO: main_bb2;

FROM: main_bb2_end;
assume(vi.1 sge 10);
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

