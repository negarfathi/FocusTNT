///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vnumber.0 := 2000000000;
var__temp_vwidth.0 := 1;
TO: main_bb1;

FROM: main_bb1;
vnumber.0 := var__temp_vnumber.0;
vwidth.0 := var__temp_vwidth.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vnumber.0 uge 10);
TO: main_bb2;

FROM: main_bb1_end;
assume(vnumber.0 ult 10);
TO: main_bb3;

FROM: main_bb2;
v1 := vnumber.0 udiv 10;
v2 := vwidth.0 + 1;
var__temp_vnumber.0 := v1;
var__temp_vwidth.0 := v2;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

