///*** 1_main ***///
START: main_bb6;

FROM: main_bb6;
flag := 0;
count := 0;
v9 := count;
TO: main_bb7;

FROM: main_bb7;
v10 := flag;
TO: main_bb7_end;

FROM: main_bb7_end;
assume((v10 == 1) || (v9 sgt 100));
TO: main_read.exit;

FROM: main_bb7_end;
assume((v10 != 1) && (v9 sle 100));
TO: main_bb8;

FROM: main_bb8;
flag := 1;
TO: main_read.exit;

FROM: main_read.exit;
TO: main_read.exit_end;

FROM: main_read.exit_end;
assume(0 <= 0);
TO: main_bb9;

FROM: main_read.exit_end;
assume(1 <= 0);
TO: main_bb7;

FROM: main_bb9;
TO: main_bb9_ret;

