///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
v0 := zero_extend(16, 32, 10);
v1 := zero_extend(16, 32, 10);
var__temp_vs.0 := 10;
TO: main_bb1;

FROM: main_bb1;
vs.0 := var__temp_vs.0;
v2 := zero_extend(16, 32, vs.0);
v3 := v0 + v1;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v2 slt v3);
TO: main_bb2;

FROM: main_bb1_end;
assume(v2 sge v3);
TO: main_bb3;

FROM: main_bb2;
v5 := vs.0 + 1;
var__temp_vs.0 := v5;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

