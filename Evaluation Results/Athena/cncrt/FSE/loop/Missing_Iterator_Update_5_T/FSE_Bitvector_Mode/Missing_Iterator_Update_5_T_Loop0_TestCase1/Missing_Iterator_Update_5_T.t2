///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
vmcelog_entry := nondet();
TO: main_bb0_end;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb8;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1;
var__temp_vi.0 := 0;
TO: main_bb2;

FROM: main_bb2;
vi.0 := var__temp_vi.0;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(vi.0 slt 0);
TO: main_bb3;

FROM: main_bb2_end;
assume(vi.0 sge 0);
TO: main_bb4;

FROM: main_bb3;
v4 := vi.0 + 1;
var__temp_vi.0 := v4;
TO: main_bb2;

FROM: main_bb4;
var__temp_ventry.0 := 0;
TO: main_bb4_end;

FROM: main_bb4_end;
assume(1 <= 0);
TO: main_bb8;

FROM: main_bb4_end;
assume(0 <= 0);
TO: main_bb5;

FROM: main_bb5;
ventry.0 := var__temp_ventry.0;
TO: main_bb5_end;

FROM: main_bb5_end;
assume(ventry.0 sge 0);
TO: main_bb8;

FROM: main_bb5_end;
assume(ventry.0 slt 0);
TO: main_bb6;

FROM: main_bb6;
v7 := sign_extend(32, 64, ventry.0);
v8 := v7;
v9 := select_array(vmcelog_entry, v8);
TO: main_bb6_end;

FROM: main_bb6_end;
assume(v9 != 0);
TO: main_bb7;

FROM: main_bb6_end;
assume(v9 == 0);
TO: main_bb8;

FROM: main_bb7;
v11 := ventry.0 + 1;
var__temp_ventry.0 := v11;
TO: main_bb5;

FROM: main_bb8;
TO: main_bb8_ret;

