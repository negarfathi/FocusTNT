///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vcur.0 := 2;
TO: main_bb0_end;

FROM: main_bb0_end;
assume(0 <= 0);
TO: main_bb2;

FROM: main_bb0_end;
assume(1 <= 0);
TO: main_bb1;

FROM: main_bb1;
vcur.0 := var__temp_vcur.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(-1 ult vcur.0);
TO: main_bb2;

FROM: main_bb1_end;
assume(-1 uge vcur.0);
TO: main_bb3;

FROM: main_bb2;
TO: main_bb2_ret;

FROM: main_bb3;
v3 := vcur.0 + 2;
var__temp_vcur.0 := v3;
TO: main_bb1;

