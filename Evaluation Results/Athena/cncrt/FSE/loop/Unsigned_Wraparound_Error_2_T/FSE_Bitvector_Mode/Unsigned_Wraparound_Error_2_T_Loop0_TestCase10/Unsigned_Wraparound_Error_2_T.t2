///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vui.0 := 1;
TO: main_bb1;

FROM: main_bb1;
vui.0 := var__temp_vui.0;
v1 := vui.0 * 2;
TO: main_bb1_end;

FROM: main_bb1_end;
assume((vui.0 ult -1) && (v1 ugt vui.0));
TO: main_bb2;

FROM: main_bb1_end;
assume((vui.0 uge -1) || (v1 ule vui.0));
TO: main_.critedge;

FROM: main_bb2;
v3 := vui.0 * 2;
var__temp_vui.0 := v3;
TO: main_bb1;

FROM: main_.critedge;
TO: main_.critedge_ret;

