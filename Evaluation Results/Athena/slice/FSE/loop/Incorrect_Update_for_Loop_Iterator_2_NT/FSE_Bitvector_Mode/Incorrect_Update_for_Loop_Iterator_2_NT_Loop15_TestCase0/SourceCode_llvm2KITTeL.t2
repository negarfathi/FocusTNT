///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
v0 := nondet();
var__temp_vl.0 := v0;
TO: main_bb1;

FROM: main_bb1;
vl.0 := var__temp_vl.0;
v1 := zero_extend(8, 32, vl.0);
v2 := v1 - 1;
v3 := extract(7, 0, v2);
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vl.0 != 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vl.0 == 0);
TO: main_bb3;

FROM: main_bb2;
v5 := zero_extend(8, 32, v3);
v6 := v5 - 1;
v7 := extract(7, 0, v6);
var__temp_vl.0 := v7;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

