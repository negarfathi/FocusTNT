///*** 1_main ***///
START: main_bb1;

TYPE v1: bv(32);

FROM: main_bb1;
__fc_errno := 0;
v1 := nondet();
TO: main_bb1_end;

FROM: main_bb1_end;
assume(v1 == 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(v1 != 0);
TO: main_bb3;

FROM: main_bb2;
v3 := nondet();
v5 := __fc_errno;
TO: main_bb2_end;

FROM: main_bb2_end;
assume((v3 slt 0) && (v5 == 1));
TO: main_bb2;

FROM: main_bb2_end;
assume((v3 sge 0) || (v5 != 1));
TO: main_bb3;

FROM: main_bb3;
TO: main_bb3_ret;

