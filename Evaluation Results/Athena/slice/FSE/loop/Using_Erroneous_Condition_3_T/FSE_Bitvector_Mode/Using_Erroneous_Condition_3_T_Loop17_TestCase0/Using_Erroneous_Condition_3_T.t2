///*** 1_main ***///
START: main_bb0;

TYPE v1: bv(32);
TYPE v4: bv(32);

FROM: main_bb0;
vold_ := nondet();
vnew_ := nondet();
var__temp_vj.0 := 0;
TO: main_bb1;

FROM: main_bb1;
vj.0 := var__temp_vj.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vj.0 slt 9);
TO: main_bb2;

FROM: main_bb1_end;
assume(vj.0 sge 9);
TO: main_bb3;

FROM: main_bb2;
v1 := nondet();
v2 := sign_extend(32, 64, vj.0);
v3 := v2;
vold_ := store_array(vold_, v3, v1);
v4 := nondet();
v5 := sign_extend(32, 64, vj.0);
v6 := v5;
vnew_ := store_array(vnew_, v6, v4);
v7 := vj.0 + 1;
var__temp_vj.0 := v7;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

