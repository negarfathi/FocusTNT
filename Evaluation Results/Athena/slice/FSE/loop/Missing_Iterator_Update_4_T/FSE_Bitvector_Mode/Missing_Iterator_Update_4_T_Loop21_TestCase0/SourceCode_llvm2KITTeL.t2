///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
v0 := nondet();
v1 := nondet();
var__temp_vx.0 := 0;
TO: main_bb0_end;

FROM: main_bb0_end;
assume((((v0 slt 0) || (v1 slt 0)) || (v0 sgt 65534)) || (v1 sgt 65534));
TO: main_bb5;

FROM: main_bb0_end;
assume((((v0 sge 0) && (v1 sge 0)) && (v0 sle 65534)) && (v1 sle 65534));
TO: main_bb1;

FROM: main_bb1;
vx.0 := var__temp_vx.0;
var__temp_vy.0 := 0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vx.0 slt v0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vx.0 sge v0);
TO: main_bb5;

FROM: main_bb2;
vy.0 := var__temp_vy.0;
TO: main_bb2_end;

FROM: main_bb2_end;
assume(vy.0 slt v1);
TO: main_bb3;

FROM: main_bb2_end;
assume(vy.0 sge v1);
TO: main_bb4;

FROM: main_bb3;
v8 := vy.0 + 1;
var__temp_vy.0 := v8;
TO: main_bb2;

FROM: main_bb4;
v9 := vx.0 + 1;
var__temp_vx.0 := v9;
TO: main_bb1;

FROM: main_bb5;
TO: main_bb5_ret;

