TO: main_bb1_end;

FROM: main_bb1_end;
assume(vx.0 slt v0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vx.0 sge v0);
TO: main_bb3;

FROM: main_bb2;
v7 := vx.0 + 1;
var__temp_vx.0 := v7;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

