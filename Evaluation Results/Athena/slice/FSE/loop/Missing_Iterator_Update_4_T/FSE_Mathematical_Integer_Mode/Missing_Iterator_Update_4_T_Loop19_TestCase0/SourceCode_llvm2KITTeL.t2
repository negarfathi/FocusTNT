///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
v0 := nondet();
v1 := nondet();
var__temp_vx.0 := 0;
TO: main_bb0_end;

FROM: main_bb0_end;
assume((((v0 slt 0) || (v1 slt 0)) || (v0 sgt 65534)) || (v1 sgt 65534));
TO: main_bb3;

FROM: main_bb0_end;
assume((((v0 sge 0) && (v1 sge 0)) && (v0 sle 65534)) && (v1 sle 65534));
TO: main_bb1;

FROM: main_bb1;
