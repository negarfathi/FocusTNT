///*** 1_main ***///
START: main_bb0;

TYPE v1: bv(32);
TYPE v4: bv(32);

FROM: main_bb0;
vslots_used := nondet();
vereg := nondet();
var__temp_vi.0 := 0;
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 slt 10);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sge 10);
TO: main_bb3;

FROM: main_bb2;
v1 := nondet();
v2 := sign_extend(32, 64, vi.0);
v3 := v2;
vslots_used := store_array(vslots_used, v3, v1);
v4 := nondet();
v5 := sign_extend(32, 64, vi.0);
v6 := v5;
vereg := store_array(vereg, v6, v4);
v7 := vi.0 + 1;
var__temp_vi.0 := v7;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

