///*** 1_main ***///
START: main_bb0;
TYPE dummy: bv(32);


FROM: main_bb0;
var__temp_vdiv2.0 := 7;
TO: main_bb1;

FROM: main_bb1;
vdiv2.0 := var__temp_vdiv2.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vdiv2.0 uge 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vdiv2.0 ult 0);
TO: main_bb3;

FROM: main_bb2;
v1 := vdiv2.0 + -1;
var__temp_vdiv2.0 := v1;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

