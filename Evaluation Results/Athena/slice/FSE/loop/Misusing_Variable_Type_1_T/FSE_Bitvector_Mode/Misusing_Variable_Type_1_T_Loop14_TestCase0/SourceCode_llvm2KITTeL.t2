///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
var__temp_vdiv1.0 := 1;
TO: main_bb1;

FROM: main_bb1;
vdiv1.0 := var__temp_vdiv1.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vdiv1.0 sge 0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vdiv1.0 slt 0);
TO: main_bb3;

FROM: main_bb2;
v1 := vdiv1.0 + -1;
var__temp_vdiv1.0 := v1;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

