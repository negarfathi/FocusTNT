///*** 1_main ***///
START: main_bb0;

FROM: main_bb0;
v0 := nondet();
var__temp_vi.0 := 10;
TO: main_bb1;

FROM: main_bb1;
vi.0 := var__temp_vi.0;
TO: main_bb1_end;

FROM: main_bb1_end;
assume(vi.0 sle v0);
TO: main_bb2;

FROM: main_bb1_end;
assume(vi.0 sgt v0);
TO: main_bb3;

FROM: main_bb2;
v2 := vi.0 * 10;
var__temp_vi.0 := v2;
TO: main_bb1;

FROM: main_bb3;
TO: main_bb3_ret;

