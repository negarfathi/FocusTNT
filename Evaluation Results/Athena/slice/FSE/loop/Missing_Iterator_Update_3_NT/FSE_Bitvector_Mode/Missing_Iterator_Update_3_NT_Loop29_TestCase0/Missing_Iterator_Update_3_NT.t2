assume(v3 sle 0);
TO: main_bb6;

FROM: main_bb1_end;
assume(v3 sgt 0);
TO: main_bb2;

FROM: main_bb2;
v5 := sign_extend(32, 64, v3);
v6 := 4 * v5;
var__temp_vi.0 := 0;
TO: main_bb3;

FROM: main_bb3;
vi.0 := var__temp_vi.0;
v9 := v3 - 1;
TO: main_bb3_end;

FROM: main_bb3_end;
assume(vi.0 slt v9);
TO: main_bb4;

FROM: main_bb3_end;
assume(vi.0 sge v9);
