FROM: main_bb4;
v11 := nondet();
v12 := v8 + vi.0;
v13 := sign_extend(32, 64, v12);
v14 := v13;
vmemory0 := store_array(vmemory0, v14, v11);
v15 := vi.0 + 1;
var__temp_vi.0 := v15;
